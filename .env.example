# AI & LLM (OpenRouter / Vertex AI)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_key_here
GOOGLE_VERTEX_PROJECT=your_gcp_project_id
GOOGLE_VERTEX_LOCATION=europe-west1

# Vector DB (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_key_here

# Main Database (Supabase / PostgreSQL)
# -----------------------------------------------------------------------------
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=your_supabase_role_key_here
DATABASE_URL=postgresql://postgres:password@localhost:5432/are

# CRM Integration (HubSpot)
# -----------------------------------------------------------------------------
HUBSPOT_ACCESS_TOKEN=your_hubspot_token_here

# Pipeline Settings
# -----------------------------------------------------------------------------
PII_REDACTION_LOCAL=true
PIPELINE_MAX_CONCURRENCY=10
LOG_LEVEL=info
